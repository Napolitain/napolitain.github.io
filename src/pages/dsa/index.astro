---
import AtlasBreadcrumbs from '@/components/discovery/AtlasBreadcrumbs.astro';
import RecentAtlasHistory from '@/components/discovery/RecentAtlasHistory.svelte';
import DsaIndex from '@/components/dsa/DsaIndex.svelte';
import Layout from '@/layouts/Layout.astro';
import { buildDsaDirectory } from '@/lib/dsa';
import { getCollection } from 'astro:content';

const allTopics = await getCollection('dsa', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const directory = buildDsaDirectory(allTopics);
---

<Layout
  title="DSA Atlas - Napolitain"
  description="Navigate data structures and algorithms by family, prerequisites, and what each topic enables."
>
  <div class="min-h-screen">
    <section class="px-8 pt-40 pb-20 mt-20">
      <div class="max-w-6xl mx-auto text-center space-y-6">
        <div class="text-left">
          <AtlasBreadcrumbs sectionLabel="DSA Atlas" sectionHref="/dsa" currentTitle="Overview" />
        </div>
        <p class="text-sm uppercase tracking-[0.4em] text-muted-foreground">Data structures & algorithms</p>
        <h1 class="text-5xl md:text-6xl font-bold">DSA Atlas</h1>
        <p class="text-xl text-muted-foreground max-w-3xl mx-auto leading-relaxed">
          Explore concepts as a connected map instead of a flat list. Follow families, see prerequisites, and understand what each topic unlocks next.
        </p>
      </div>
    </section>

    <section class="pb-40 px-8">
      <div class="max-w-6xl mx-auto space-y-10">
        <section class="rounded-3xl border border-border bg-card p-6 md:p-8">
          <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-3xl space-y-3">
              <p class="text-xs uppercase tracking-[0.3em] text-muted-foreground">New learning track</p>
              <h2 class="text-2xl font-semibold">System design now sits alongside the DSA atlas</h2>
              <p class="text-sm md:text-base text-muted-foreground leading-relaxed">
                If you want to move from algorithmic building blocks into production architecture, start the new system design atlas with a deep dive on designing a rate limiter at scale.
              </p>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row">
              <a
                href="/system-design"
                class="inline-flex items-center justify-center rounded-full border border-border px-4 py-2 text-sm font-medium transition-colors hover:border-primary/40 hover:text-primary"
              >
                Open system design atlas
              </a>
              <a
                href="/system-design/designing-a-rate-limiter"
                class="inline-flex items-center justify-center rounded-full bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
              >
                Read rate limiter deep dive
              </a>
            </div>
          </div>
        </section>

        <RecentAtlasHistory
          client:load
          title="Recently viewed atlas topics"
          description="Keep your last DSA, system design, and graphics visits close while you continue exploring the atlas."
        />
        {directory.topics.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-muted-foreground text-lg">No DSA topics yet. Check back soon!</p>
          </div>
        ) : (
          <DsaIndex
            client:load
            topics={directory.topics}
            families={directory.families}
            paths={directory.paths}
            stats={directory.stats}
          />
        )}
      </div>
    </section>

    <footer class="py-16 px-8 border-t border-border">
      <div class="max-w-6xl mx-auto text-center text-sm text-muted-foreground">
        <p>© {new Date().getFullYear()} Napolitain. Built with Astro, Svelte & TypeScript.</p>
      </div>
    </footer>
  </div>
</Layout>
