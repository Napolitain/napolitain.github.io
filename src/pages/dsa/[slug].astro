---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { ArrowLeft, Tag } from 'phosphor-svelte';
import Badge from '@/components/ui/badge.svelte';
import ReadingProgress from '@/components/ReadingProgress.svelte';
import TableOfContents from '@/components/TableOfContents.svelte';
import BfsVisualization from '@/components/dsa/visualizations/BfsVisualization.svelte';
import DfsVisualization from '@/components/dsa/visualizations/DfsVisualization.svelte';
import DijkstraVisualization from '@/components/dsa/visualizations/DijkstraVisualization.svelte';
import TopoSortVisualization from '@/components/dsa/visualizations/TopoSortVisualization.svelte';
import UnionFindVisualization from '@/components/dsa/visualizations/UnionFindVisualization.svelte';
import BinarySearchVisualization from '@/components/dsa/visualizations/BinarySearchVisualization.svelte';
import MergeSortVisualization from '@/components/dsa/visualizations/MergeSortVisualization.svelte';
import QuickSortVisualization from '@/components/dsa/visualizations/QuickSortVisualization.svelte';
import LinkedListVisualization from '@/components/dsa/visualizations/LinkedListVisualization.svelte';
import TwoPointersVisualization from '@/components/dsa/visualizations/TwoPointersVisualization.svelte';
import HeapVisualization from '@/components/dsa/visualizations/HeapVisualization.svelte';
import DpVisualization from '@/components/dsa/visualizations/DpVisualization.svelte';
import GreedyVisualization from '@/components/dsa/visualizations/GreedyVisualization.svelte';
import TrieVisualization from '@/components/dsa/visualizations/TrieVisualization.svelte';
import MstVisualization from '@/components/dsa/visualizations/MstVisualization.svelte';
import MonotonicStackVisualization from '@/components/dsa/visualizations/MonotonicStackVisualization.svelte';
import SegmentTreeVisualization from '@/components/dsa/visualizations/SegmentTreeVisualization.svelte';
import BstVisualization from '@/components/dsa/visualizations/BstVisualization.svelte';
import BacktrackingVisualization from '@/components/dsa/visualizations/BacktrackingVisualization.svelte';
import BitManipulationVisualization from '@/components/dsa/visualizations/BitManipulationVisualization.svelte';
import HashMapVisualization from '@/components/dsa/visualizations/HashMapVisualization.svelte';

export async function getStaticPaths() {
  const entries = await getCollection('dsa', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'dsa'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const viz = entry.data.visualization;
---

<Layout
  title={`${entry.data.title} - DSA - Napolitain`}
  description={entry.data.description}
>
  <div class="min-h-screen">
    <ReadingProgress client:load />
    <TableOfContents client:load />
    <div class="max-w-3xl mx-auto px-6 pt-20">
      <a
        href="/dsa"
        class="inline-flex items-center gap-2 text-muted-foreground hover:text-primary transition-colors mb-12"
      >
        <ArrowLeft client:load size={20} />
        Back to DSA
      </a>
    </div>

    <article class="max-w-3xl mx-auto px-6 py-20">
      <header class="mb-16 space-y-6">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground leading-tight font-serif">
          {entry.data.title}
        </h1>

        <p class="text-lg text-muted-foreground leading-relaxed font-serif">
          {entry.data.description}
        </p>

        {entry.data.tags.length > 0 && (
          <div class="flex items-center gap-2">
            <Tag client:load size={16} class="text-muted-foreground" />
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag: string) => (
                <Badge client:load variant="secondary" class="text-xs">
                  {tag}
                </Badge>
              ))}
            </div>
          </div>
        )}
      </header>

      <!-- Visualization -->
      {viz === 'BfsVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <BfsVisualization client:load />
        </section>
      )}
      {viz === 'DfsVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <DfsVisualization client:load />
        </section>
      )}
      {viz === 'DijkstraVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <DijkstraVisualization client:load />
        </section>
      )}
      {viz === 'TopoSortVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <TopoSortVisualization client:load />
        </section>
      )}
      {viz === 'UnionFindVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <UnionFindVisualization client:load />
        </section>
      )}
      {viz === 'BinarySearchVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <BinarySearchVisualization client:load />
        </section>
      )}
      {viz === 'MergeSortVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <MergeSortVisualization client:load />
        </section>
      )}
      {viz === 'QuickSortVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <QuickSortVisualization client:load />
        </section>
      )}
      {viz === 'LinkedListVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <LinkedListVisualization client:load />
        </section>
      )}
      {viz === 'TwoPointersVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <TwoPointersVisualization client:load />
        </section>
      )}
      {viz === 'HeapVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <HeapVisualization client:load />
        </section>
      )}
      {viz === 'DpVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <DpVisualization client:load />
        </section>
      )}
      {viz === 'GreedyVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <GreedyVisualization client:load />
        </section>
      )}
      {viz === 'TrieVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <TrieVisualization client:load />
        </section>
      )}
      {viz === 'MstVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <MstVisualization client:load />
        </section>
      )}
      {viz === 'MonotonicStackVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <MonotonicStackVisualization client:load />
        </section>
      )}
      {viz === 'SegmentTreeVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <SegmentTreeVisualization client:load />
        </section>
      )}
      {viz === 'BstVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <BstVisualization client:load />
        </section>
      )}
      {viz === 'BacktrackingVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <BacktrackingVisualization client:load />
        </section>
      )}
      {viz === 'BitManipulationVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <BitManipulationVisualization client:load />
        </section>
      )}
      {viz === 'HashMapVisualization' && (
        <section class="mb-16 p-6 rounded-xl border border-border bg-card">
          <h2 class="text-lg font-semibold mb-6">Interactive Visualization</h2>
          <HashMapVisualization client:load />
        </section>
      )}

      <!-- Article Content -->
      <div class="prose prose-lg prose-slate dark:prose-invert max-w-3xl mx-auto font-serif">
        <Content />
      </div>
    </article>

    <footer class="py-16 px-8 border-t border-border mt-20">
      <div class="max-w-6xl mx-auto text-center text-sm text-muted-foreground">
        <p>© {new Date().getFullYear()} Napolitain. Built with Astro, Svelte & TypeScript.</p>
      </div>
    </footer>
  </div>
</Layout>
